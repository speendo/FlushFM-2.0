{
  "name": "Debian-Trixie-PIO-Sandbox",
  // Wir nutzen direkt das offizielle Debian Stable Image
  "image": "debian:stable-slim",

  "features": {
    // Installiert Python & Pip automatisch
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11" 
    },
    // Installiert Git für Versionsverwaltung
    "ghcr.io/devcontainers/features/git:1": {}
  },

  // PlatformIO CLI nach dem Start installieren
  "postCreateCommand": "pip install -U platformio",

  "customizations": {
    "vscode": {
      "extensions": ["platformio.platformio-ide"]
    }
  },

  "runArgs": [
    "--privileged",
    "--device=/dev/ttyUSB0:/dev/ttyUSB0"
  ],
  
  "remoteUser": "root" 
}